pipeline {
  agent any

  options { timestamps() }

  stages {
    stage('Docker version') {
      steps {
        sh '''
          set -e
          docker version
        '''
      }
    }

    stage('Compose version') {
      steps {
        sh '''
          set -e
          docker compose version
        '''
      }
    }

    stage('Deploy Backends') {
      steps {
        sh '''
          set -e
          docker compose -f docker-compose.yml up -d --build backend backend2
        '''
      }
    }

    stage('Show running containers') {
      steps {
        sh '''
          set -e
          docker ps
        '''
      }
    }
  }
}